###############################################################################
# Dockerfile for running openleadr-rs cargo tests.
#
# Build context: ../openleadr-rs (the submodule root)
# Used by: tests/docker-compose.openleadr-test.yml
#
# Compiled artifacts live in named Docker volumes (see docker-compose), so
# only changed crates are recompiled on each run. First run is slow (~25 min
# on Pi4 ARM64); subsequent runs are ~1-2 min.
###############################################################################

FROM rust:1.90-alpine
RUN apk add --no-cache alpine-sdk openssl-dev openssl-libs-static
WORKDIR /app
COPY . .
ENV SQLX_OFFLINE=true
ENV RUST_BACKTRACE=1
ENV CARGO_BUILD_JOBS=1
CMD ["cargo", "test", "--workspace"]
