###############################################################################
# Dockerfile for running openleadr-rs cargo tests.
#
# Build context: ../openleadr-rs (the submodule root)
# Used by: tests/docker-compose.cargo-test.yml
#
# Uses the same base as vtn.Dockerfile so layers are cached.
# Cargo registry and target dir are mounted as named volumes
# (declared in docker-compose) for fast re-runs.
###############################################################################
FROM rust:1.90-alpine AS base
RUN apk add --no-cache alpine-sdk openssl-dev openssl-libs-static

FROM base
COPY . /app
WORKDIR /app
ENV SQLX_OFFLINE=true
ENV RUST_BACKTRACE=1
# CARGO_HOME is mounted as a named volume to cache the registry across runs
ENV CARGO_HOME=/cargo-cache
CMD ["cargo", "test", "--workspace"]
