# OpenADR VTN Stack — Environment Variables
# See: vtn_setup_from_blog_step_by_step.md

# PostgreSQL
PG_USER=openadr
PG_DB=openadr
PG_PASSWORD=openadr
PG_PORT=5432
PG_TZ=UTC

# VTN
VTN_PORT=3000
RUST_LOG=info
DATABASE_URL=postgres://openadr:openadr@db:5432/openadr

# OAuth (internal provider defaults — VTN auto-generates HMAC secret if omitted)
# OAUTH_TYPE=INTERNAL
# OAUTH_KEY_TYPE=HMAC
# OAUTH_BASE64_SECRET=
